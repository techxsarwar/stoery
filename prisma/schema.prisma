generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(AUTHOR)
  accounts      Account[]
  profile       Profile?
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id                   String             @id @default(cuid())
  full_name            String?
  pen_name             String?            @unique
  age                  Int?
  parentage            String?
  guardian_approved    Boolean            @default(false)
  userId               String             @unique
  bank_account_holder  String?
  bank_account_number  String?
  ifsc_code            String?
  legal_name           String?
  monetization_status  MonetizationStatus @default(NONE)
  pan_number           String?
  phone_number         String?
  reading_time_seconds BigInt             @default(0)
  isVerified           Boolean            @default(false)
  avatar_url           String?
  bio                  String?
  username             String?            @unique
  reading_streak       Int                @default(0)
  longest_streak       Int                @default(0)
  last_reading_date    DateTime?
  authorPosts          AuthorPost[]
  codexEntries         CodexEntry[]
  comments             Comment[]
  following            Follow[]           @relation("Follower")
  followers            Follow[]           @relation("Following")
  licenses             License[]
  likes                Like[]
  nexusMessages        NexusMessage[]
  postLikes            PostLike[]
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports              Report[]
  stories              Story[]
  readingHistory       ReadingHistory[]
  notifications        Notification[]
  reviews              Review[]
  badges               Badge[]
}

model Story {
  id                   String       @id @default(cuid())
  title                String
  content              String?
  genre                String?
  cover_url            String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  authorId             String
  status               StoryStatus  @default(PUBLISHED)
  description          String?
  reads                Int          @default(0)
  reading_time_seconds BigInt       @default(0)
  isBanned             Boolean      @default(false)
  banReason            String?
  appealStatus         AppealStatus @default(NONE)
  appealText           String?
  banExpiresAt         DateTime?
  isPermanentBan       Boolean      @default(false)
  authorPosts          AuthorPost[]
  chapters             Chapter[]
  comments             Comment[]
  license              License?
  likes                Like[]
  reports              Report[]
  author               Profile          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  readingHistory       ReadingHistory[]
  reviews              Review[]
}

model Report {
  id             String       @id @default(cuid())
  reason         String
  details        String?
  status         ReportStatus @default(PENDING)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  storyId        String
  reporterId     String
  authorResponse String?
  reporter       Profile      @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  story          Story        @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model Chapter {
  id        String   @id @default(cuid())
  title     String
  content   String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  profileId String
  storyId   String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([profileId, storyId])
}

model Comment {
  id             String   @id @default(cuid())
  content        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  profileId      String
  storyId        String
  isShadowBanned Boolean  @default(false)
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  story          Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model CodexEntry {
  id        String   @id @default(cuid())
  profileId String
  title     String
  category  String
  content   String
  image_url String?
  isPrivate Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model NexusMessage {
  id        String   @id @default(cuid())
  content   String
  profileId String
  createdAt DateTime @default(now())
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model License {
  id            String        @id @default(cuid())
  storyId       String        @unique
  applicantId   String
  status        LicenseStatus @default(PENDING)
  legalName     String
  licenseType   String
  details       String?
  issuedAt      DateTime?
  licenseNumber String?       @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  applicant     Profile       @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  story         Story         @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    Profile  @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   Profile  @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model AuthorPost {
  id        String     @id @default(cuid())
  content   String     @default("")
  profileId String
  storyId   String?
  createdAt DateTime   @default(now())
  image_url String?
  profile   Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  story     Story?     @relation(fields: [storyId], references: [id])
  likes     PostLike[]
}

model PostLike {
  id        String     @id @default(cuid())
  postId    String
  profileId String
  createdAt DateTime   @default(now())
  post      AuthorPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  profile   Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([postId, profileId])
}

model ReadingHistory {
  id              String   @id @default(cuid())
  profileId       String
  storyId         String
  chapterId       String?
  scrollProgress  Float    @default(0)
  lastReadAt      DateTime @default(now())
  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  story           Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  
  @@unique([profileId, storyId])
}

model Notification {
  id          String   @id @default(cuid())
  profileId   String
  type        String   // NEW_CHAPTER, COMMENT_REPLY, LICENSE_APPROVED, BADGE_EARNED
  title       String
  message     String
  link        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Review {
  id          String   @id @default(cuid())
  profileId   String
  storyId     String
  rating      Int      // 1-5
  title       String?
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([profileId, storyId])
}

model Badge {
  id          String   @id @default(cuid())
  profileId   String
  badgeType   String   // SCHOLAR_OF_VOID, FIRST_BLOOD, etc.
  earnedAt    DateTime @default(now())
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, badgeType])
}

enum UserRole {
  AUTHOR
  EMPLOYEE
  ADMIN
  MANAGER
}

enum StoryStatus {
  PUBLISHED
  PAUSED
  DRAFT
}

enum MonetizationStatus {
  NONE
  ELIGIBLE
  APPLIED
  APPROVED
  REJECTED
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum AppealStatus {
  NONE
  SUBMITTED
  ACCEPTED
  REJECTED
}

enum LicenseStatus {
  PENDING
  APPROVED
  REJECTED
}

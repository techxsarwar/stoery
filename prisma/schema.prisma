// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// NextAuth Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(AUTHOR)
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  AUTHOR
  EMPLOYEE
  ADMIN
}

enum StoryStatus {
  PUBLISHED
  PAUSED
  DRAFT
}

enum MonetizationStatus {
  NONE
  ELIGIBLE
  APPLIED
  APPROVED
  REJECTED
}

// Business Domain Models
model Profile {
  id               String   @id @default(cuid())
  full_name        String?
  pen_name         String?  @unique
  age              Int?
  parentage        String?
  guardian_approved Boolean @default(false)
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Monetization fields
  reading_time_seconds BigInt @default(0)
  monetization_status MonetizationStatus @default(NONE)
  legal_name           String?
  pan_number           String?
  bank_account_number  String?
  ifsc_code           String?
  bank_account_holder  String?
  phone_number         String?
  isVerified           Boolean @default(false)

  stories      Story[]
  likes        Like[]
  comments     Comment[]
  codexEntries CodexEntry[]
  nexusMessages NexusMessage[]
  reports      Report[]
}

model Story {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  content     String?  @db.Text
  genre       String?
  cover_url   String?
  status      StoryStatus @default(PUBLISHED)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  authorId    String
  reads       Int      @default(0)
  reading_time_seconds BigInt @default(0)
  isBanned        Boolean  @default(false)
  banReason       String?  @db.Text
  banExpiresAt    DateTime?
  appealText      String?  @db.Text
  appealStatus    AppealStatus @default(NONE)
  isPermanentBan  Boolean  @default(false)

  author   Profile   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  chapters Chapter[]
  likes    Like[]
  comments Comment[]
  reports  Report[]
}

model Report {
  id              String   @id @default(cuid())
  reason          String   @db.Text
  details         String?  @db.Text
  authorResponse  String?  @db.Text
  status          ReportStatus @default(PENDING)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  storyId         String
  story           Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  
  reporterId      String
  reporter        Profile  @relation(fields: [reporterId], references: [id], onDelete: Cascade)
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum AppealStatus {
  NONE
  SUBMITTED
  ACCEPTED
  REJECTED
}


model Chapter {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  storyId   String

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  profileId String
  storyId   String

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  story   Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([profileId, storyId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profileId String
  storyId   String
  isShadowBanned Boolean @default(false)

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  story   Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model CodexEntry {
  id        String   @id @default(cuid())
  profileId String
  title     String
  category  String   // "Character", "Location", "Artifact", "Lore"
  content   String   @db.Text
  image_url String?
  isPrivate Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model NexusMessage {
  id        String   @id @default(cuid())
  content   String
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
